# Copy this file to `.env` and replace the placeholder with your real key.
# `GOOGLE_API_KEY` also works if that is the key name you already use elsewhere.
GEMINI_API_KEY=your_gemini_api_key_here
ANALYSIS_MODEL=gemini-3-flash-preview
SEARCH_MODEL=gemini-3-flash-preview
IMAGE_MODEL=gemini-2.5-flash-image
MOCK_FALLBACK_ENABLED=true
VISUALIZATION_JOBS_ENABLED=false
VISUALIZATION_JOBS_BUCKET=
VISUALIZATION_JOBS_QUEUE_URL=
VISUALIZATION_JOBS_PREFIX=visualization-jobs
VISUALIZATION_JOB_POLL_MS=1500
VISUALIZATION_WORKER_CONCURRENCY=2
VISUALIZATION_WORKER_WAIT_SECONDS=20
